# .gitignore — proxmox-cicd
#
# Mirrors proxmox-vms/.gitignore + proxmox-k3s/.gitignore so the
# three repos share the same hygiene rules.

# Operator secrets + state. Never commit.
.env
.env.*
!.env.example
*.tfvars
*.tfvars.json
terraform.tfstate
terraform.tfstate.*
*.tfstate.backup

# Python build / test / lint artefacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Provisioner state. Each `infra/clusters/<name>/` directory
# is operator-local: catalog.yaml + kubeconfig.yaml + apps.json
# are generated on first apply and never committed. The
# committed template is `infra/clusters/catalog.yaml.example`
# — cp it into place on first run.
infra/clusters/*
!infra/clusters/catalog.yaml.example

# Structured audit log. Generated, never source.
logs/

# Apply-rendered values files. The orchestrator writes
# `values/<name>.values-rendered.yaml` next to each
# committed `values/<name>.yaml` at apply-time, overlaying
# operator-local overrides (URLs, etc.) on top of the
# committed placeholder. Re-generated on every apply; never
# committed.
values/*.values-rendered.yaml

# Operator-scoped secrets. The cloudflared app mints a
# scoped Cloudflare API token at first apply and writes
# it here (mode 0600); subsequent applies reuse the cached
# token instead of re-prompting for the global API key.
infra/secrets/

# Editor noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS junk
Thumbs.db

# Node tooling — `npm install @mermaid-js/mermaid-cli` writes
# node_modules/ beside package.json for ad-hoc diagram validation.
node_modules/
package-lock.json
.npm/